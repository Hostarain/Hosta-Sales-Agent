# ============================================
# Hosta Sales Agent 环境变量模板
# 复制为 .env 并填入真实值
# ============================================

# --- 服务端口 ---
SERVER_PORT=8087

# --- 数据库 (MySQL) ---
DB_URL=jdbc:mysql://localhost:3306/SalesAgent
DB_USERNAME=root
DB_PASSWORD=your_db_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=0

# --- LLM (LangChain4j / DashScope 千问) ---
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your_api_key
LLM_MODEL=qwen-max

# --- 可选 ---
# LOG_LEVEL=DEBUG
# AUTH_ENABLED=false
# ANOMALY_THRESHOLD_DAYS=5
# TREND_DROP_THRESHOLD=0.3
